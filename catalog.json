{
  "widgets": [
    {
      "metadata": {
        "type": "WorkflowViewer",
        "tier": 2,
        "description": "Interactive flowchart viewer for Tercen workflows. Displays steps as a DAG with connectors, supports selection, inline rename, run/stop/reset actions, and step state visualization. Publishes focus events when steps are selected and action events for run/stop/reset. Subscribes to step state changes from the server.",
        "props": {
          "workflowId": {
            "type": "string",
            "required": true,
            "description": "ID of the workflow to display"
          },
          "projectId": {
            "type": "string",
            "required": true,
            "description": "ID of the project containing the workflow"
          }
        },
        "emittedEvents": [
          "workflow.focusChanged",
          "workflow.openStepViewer",
          "workflow.runWorkflow",
          "workflow.stopWorkflow",
          "workflow.resetWorkflow",
          "workflow.runStep",
          "workflow.stopStep",
          "workflow.resetStep",
          "workflow.stepRenamed",
          "workflow.stepMoved"
        ],
        "acceptedActions": ["onTap", "onDoubleTap"]
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "#1E1E1E", "padding": 8 },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "Workflow Viewer", "fontSize": 13, "fontWeight": "bold", "color": "#10B981" }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-id-label",
                    "props": { "text": "{{props.workflowId}}", "fontSize": 11, "color": "grey" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "workflowService",
                  "method": "get",
                  "args": ["{{props.workflowId}}"]
                },
                "children": [
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-loading",
                    "props": { "visible": "{{loading}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-spinner",
                        "children": [
                          {
                            "type": "LoadingIndicator",
                            "id": "{{widgetId}}-li",
                            "props": { "variant": "skeleton", "text": "Loading workflow…" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-error",
                    "props": { "visible": "{{error}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-err-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-err-text",
                            "props": { "text": "Error: {{errorMessage}}", "color": "red" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-ready",
                    "props": { "visible": "{{ready}}" },
                    "children": [
                      {
                        "type": "Column",
                        "id": "{{widgetId}}-wf-col",
                        "props": { "crossAxisAlignment": "center" },
                        "children": [
                          {
                            "type": "Padding",
                            "id": "{{widgetId}}-wf-pad",
                            "props": { "padding": 16 },
                            "children": [
                              {
                                "type": "Text",
                                "id": "{{widgetId}}-wf-name",
                                "props": { "text": "{{data.name}}", "fontSize": 16, "fontWeight": "bold" }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-step-count",
                            "props": { "text": "Workflow loaded — use native viewer for full flowchart", "fontSize": 12, "color": "grey" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "DataTableViewer",
        "tier": 2,
        "description": "Tabular data viewer for Tercen workflow step tables. Fetches input or output tables for a step and displays them in browser-style tabs. Each tab shows a scrollable data table with column headers, types, and selectable cell values.",
        "props": {
          "workflowId": {
            "type": "string",
            "required": false,
            "description": "Workflow ID. If omitted, prompts user."
          },
          "stepId": {
            "type": "string",
            "required": false,
            "description": "Step ID within the workflow. If omitted, prompts user."
          },
          "tableType": {
            "type": "string",
            "required": false,
            "default": "output",
            "values": ["input", "output"],
            "description": "Whether to show input or output tables for the step."
          }
        },
        "emittedEvents": ["system.selection.table"],
        "acceptedActions": []
      },
      "template": {
        "type": "PromptRequired",
        "id": "{{widgetId}}-prompt",
        "props": {
          "fields": [
            {"name": "workflowId", "label": "Workflow ID", "default": "28e3c9888e9935f667aed6f07c007c7c"},
            {"name": "stepId", "label": "Step ID", "default": "73ab0d32-cd1a-4ee5-bdec-b744b3767b32"},
            {"name": "tableType", "label": "Table type (input or output)", "default": "output"}
          ]
        },
        "children": [{
          "type": "Column",
          "id": "{{widgetId}}-root",
          "props": {"crossAxisAlignment": "stretch"},
          "children": [
            {
              "type": "Expanded",
              "id": "{{widgetId}}-body",
              "children": [{
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "workflowService",
                  "method": "getStepTables",
                  "args": ["{{workflowId}}", "{{stepId}}", "{{tableType}}"]
                },
                "children": [
                  {
                    "type": "Conditional", "id": "{{widgetId}}-loading",
                    "props": {"visible": "{{loading}}"},
                    "children": [{"type": "Center", "id": "{{widgetId}}-spinner", "children": [{"type": "LoadingIndicator", "id": "{{widgetId}}-li", "props": {"variant": "skeleton", "text": "Loading step tables…"}}]}]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-error",
                    "props": {"visible": "{{error}}"},
                    "children": [{
                      "type": "Center", "id": "{{widgetId}}-err-center",
                      "children": [{
                        "type": "Column", "id": "{{widgetId}}-err-col", "props": {"mainAxisAlignment": "center"},
                        "children": [
                          {"type": "Icon", "id": "{{widgetId}}-err-icon", "props": {"icon": "error_outline", "size": 32, "color": "error"}},
                          {"type": "SizedBox", "id": "{{widgetId}}-err-gap", "props": {"height": 8}},
                          {"type": "Text", "id": "{{widgetId}}-err-text", "props": {"text": "{{errorMessage}}", "textStyle": "bodySmall", "color": "error"}}
                        ]
                      }]
                    }]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-ready",
                    "props": {"visible": "{{ready}}"},
                    "children": [{
                      "type": "Column",
                      "id": "{{widgetId}}-content",
                      "props": {"crossAxisAlignment": "stretch"},
                      "children": [
                        {
                          "type": "Container",
                          "id": "{{widgetId}}-toolbar",
                          "props": {"color": "surfaceContainerHigh", "padding": "sm"},
                          "children": [{
                            "type": "Row",
                            "id": "{{widgetId}}-toolbar-row",
                            "props": {"mainAxisAlignment": "spaceBetween"},
                            "children": [
                              {
                                "type": "Row", "id": "{{widgetId}}-toolbar-left",
                                "children": [
                                  {"type": "Icon", "id": "{{widgetId}}-icon", "props": {"icon": "table_chart", "size": 16, "color": "primary"}},
                                  {"type": "SizedBox", "id": "{{widgetId}}-icon-gap", "props": {"width": 8}},
                                  {"type": "Text", "id": "{{widgetId}}-title", "props": {"text": "{{data.stepName}}", "textStyle": "labelMedium", "color": "onSurface"}}
                                ]
                              },
                              {"type": "Text", "id": "{{widgetId}}-type-label", "props": {"text": "{{data.tableType}}", "textStyle": "labelSmall", "color": "onSurfaceMuted"}}
                            ]
                          }]
                        },
                        {"type": "Divider", "id": "{{widgetId}}-div", "props": {"height": 1, "color": "outlineVariant"}},
                        {
                          "type": "Expanded",
                          "id": "{{widgetId}}-tables-area",
                          "children": [{
                            "type": "TabbedDataTable",
                            "id": "{{widgetId}}-tdt",
                            "props": {
                              "tables": "{{data.tables}}",
                              "maxRows": 100
                            }
                          }]
                        }
                      ]
                    }]
                  }
                ]
              }]
            }
          ]
        }]
      }
    },
    {
      "metadata": {
        "type": "ChatBox",
        "tier": 2,
        "description": "LLM chat interface for Tercen. Displays a message thread with markdown-rich responses, syntax-highlighted code blocks, and session management. Sends user messages with focus context to the LLM and emits action intents on the EventBus (create step, open file, navigate workflows). Receives focus context from other widgets to provide situational awareness to the AI.",
        "props": {},
        "emittedEvents": [
          "createStep",
          "openFile",
          "openWorkflow",
          "navigateToStep",
          "navigateTo",
          "refreshTree",
          "workflowUpdated"
        ],
        "acceptedActions": []
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "surfaceContainerHigh", "padding": "sm" },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "IconButton",
                    "id": "{{widgetId}}-new-session",
                    "props": {
                      "icon": "add",
                      "channel": "chat.newSession",
                      "tooltip": "New Session",
                      "size": 18,
                      "color": "primary"
                    }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "Chat", "textStyle": "labelMedium", "color": "onSurface" }
                  },
                  {
                    "type": "IconButton",
                    "id": "{{widgetId}}-history",
                    "props": {
                      "icon": "schedule",
                      "channel": "chat.showHistory",
                      "tooltip": "Chat History",
                      "size": 18,
                      "color": "onSurfaceVariant"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Divider",
            "id": "{{widgetId}}-divider-top",
            "props": { "height": 1, "color": "outlineVariant" }
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "Center",
                "id": "{{widgetId}}-empty",
                "children": [
                  {
                    "type": "Column",
                    "id": "{{widgetId}}-empty-col",
                    "props": { "mainAxisAlignment": "center" },
                    "children": [
                      {
                        "type": "Icon",
                        "id": "{{widgetId}}-empty-icon",
                        "props": { "icon": "chat", "size": 48, "color": "onSurfaceMuted" }
                      },
                      {
                        "type": "SizedBox",
                        "id": "{{widgetId}}-empty-spacer",
                        "props": { "height": 12 }
                      },
                      {
                        "type": "Text",
                        "id": "{{widgetId}}-empty-msg",
                        "props": { "text": "Start a conversation", "textStyle": "titleMedium", "color": "onSurfaceVariant" }
                      },
                      {
                        "type": "SizedBox",
                        "id": "{{widgetId}}-empty-spacer2",
                        "props": { "height": 4 }
                      },
                      {
                        "type": "Text",
                        "id": "{{widgetId}}-empty-detail",
                        "props": { "text": "Ask a question or give an instruction", "textStyle": "bodySmall", "color": "onSurfaceMuted" }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Divider",
            "id": "{{widgetId}}-divider-bottom",
            "props": { "height": 1, "color": "outlineVariant" }
          },
          {
            "type": "Container",
            "id": "{{widgetId}}-compose",
            "props": { "color": "surface", "padding": "sm" },
            "children": [
              {
                "type": "Column",
                "id": "{{widgetId}}-compose-col",
                "props": { "crossAxisAlignment": "stretch" },
                "children": [
                  {
                    "type": "TextField",
                    "id": "{{widgetId}}-input",
                    "props": {
                      "hint": "Type a message...",
                      "maxLines": 4,
                      "autofocus": true
                    }
                  },
                  {
                    "type": "SizedBox",
                    "id": "{{widgetId}}-input-spacer",
                    "props": { "height": 4 }
                  },
                  {
                    "type": "Row",
                    "id": "{{widgetId}}-bottom-bar",
                    "props": { "mainAxisAlignment": "end" },
                    "children": [
                      {
                        "type": "Spacer",
                        "id": "{{widgetId}}-bar-spacer",
                        "props": {}
                      },
                      {
                        "type": "IconButton",
                        "id": "{{widgetId}}-send",
                        "props": {
                          "icon": "send",
                          "channel": "chat.send",
                          "tooltip": "Send",
                          "size": 20,
                          "color": "primary"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "DocumentViewer",
        "tier": 2,
        "description": "Document viewer for Tercen files. Fetches file metadata (name, owner, size, dates) and downloads file content as selectable text. If fileId is not provided, prompts the user.",
        "props": {
          "fileId": {
            "type": "string",
            "required": false,
            "description": "Tercen file ID to view. If omitted, prompts user."
          }
        },
        "emittedEvents": ["system.selection.file"],
        "acceptedActions": []
      },
      "template": {
        "type": "PromptRequired",
        "id": "{{widgetId}}-prompt",
        "props": {
          "fields": [
            {"name": "fileId", "label": "File ID", "default": "2076952ae523bb4d472e283b9e001298"}
          ]
        },
        "children": [{
          "type": "Column",
          "id": "{{widgetId}}-root",
          "props": {"crossAxisAlignment": "stretch"},
          "children": [
            {
              "type": "DataSource",
              "id": "{{widgetId}}-meta-ds",
              "props": {
                "service": "fileService",
                "method": "get",
                "args": ["{{fileId}}"]
              },
              "children": [{
                "type": "Container",
                "id": "{{widgetId}}-toolbar",
                "props": {"color": "surfaceContainerHigh", "padding": "sm"},
                "children": [{
                  "type": "Row",
                  "id": "{{widgetId}}-toolbar-row",
                  "props": {"mainAxisAlignment": "spaceBetween"},
                  "children": [
                    {
                      "type": "Row",
                      "id": "{{widgetId}}-toolbar-left",
                      "children": [
                        {"type": "Icon", "id": "{{widgetId}}-icon", "props": {"icon": "description", "size": 16, "color": "primary"}},
                        {"type": "SizedBox", "id": "{{widgetId}}-icon-gap", "props": {"width": 8}},
                        {
                          "type": "Conditional", "id": "{{widgetId}}-has-name",
                          "props": {"visible": "{{ready}}"},
                          "children": [
                            {"type": "Text", "id": "{{widgetId}}-title", "props": {"text": "{{data.name}}", "textStyle": "labelMedium", "color": "onSurface"}}
                          ]
                        },
                        {
                          "type": "Conditional", "id": "{{widgetId}}-no-name",
                          "props": {"visible": "{{loading}}"},
                          "children": [
                            {"type": "Text", "id": "{{widgetId}}-title-loading", "props": {"text": "Document Viewer", "textStyle": "labelMedium", "color": "onSurface"}}
                          ]
                        }
                      ]
                    },
                    {
                      "type": "Conditional", "id": "{{widgetId}}-meta-ready",
                      "props": {"visible": "{{ready}}"},
                      "children": [{
                        "type": "Row",
                        "id": "{{widgetId}}-meta-row",
                        "children": [
                          {"type": "Icon", "id": "{{widgetId}}-owner-icon", "props": {"icon": "person", "size": 14, "color": "onSurfaceMuted"}},
                          {"type": "SizedBox", "id": "{{widgetId}}-og", "props": {"width": 4}},
                          {"type": "Text", "id": "{{widgetId}}-owner", "props": {"text": "{{data.acl.owner}}", "textStyle": "labelSmall", "color": "onSurfaceMuted"}},
                          {"type": "SizedBox", "id": "{{widgetId}}-sep1", "props": {"width": 16}},
                          {"type": "Icon", "id": "{{widgetId}}-size-icon", "props": {"icon": "storage", "size": 14, "color": "onSurfaceMuted"}},
                          {"type": "SizedBox", "id": "{{widgetId}}-sg", "props": {"width": 4}},
                          {"type": "Text", "id": "{{widgetId}}-size", "props": {"text": "{{data.size}} bytes", "textStyle": "labelSmall", "color": "onSurfaceMuted"}}
                        ]
                      }]
                    }
                  ]
                }]
              }]
            },
            {"type": "Divider", "id": "{{widgetId}}-div-top", "props": {"height": 1, "color": "outlineVariant"}},
            {
              "type": "Expanded",
              "id": "{{widgetId}}-body",
              "children": [{
                "type": "DataSource",
                "id": "{{widgetId}}-content-ds",
                "props": {
                  "service": "fileService",
                  "method": "download",
                  "args": ["{{fileId}}"]
                },
                "children": [
                  {
                    "type": "Conditional", "id": "{{widgetId}}-loading",
                    "props": {"visible": "{{loading}}"},
                    "children": [{"type": "Center", "id": "{{widgetId}}-spinner", "children": [{"type": "LoadingIndicator", "id": "{{widgetId}}-li", "props": {"variant": "skeleton", "text": "Loading document…"}}]}]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-error",
                    "props": {"visible": "{{error}}"},
                    "children": [{
                      "type": "Center", "id": "{{widgetId}}-err-center",
                      "children": [{
                        "type": "Column", "id": "{{widgetId}}-err-col",
                        "props": {"mainAxisAlignment": "center"},
                        "children": [
                          {"type": "Icon", "id": "{{widgetId}}-err-icon", "props": {"icon": "error_outline", "size": 32, "color": "error"}},
                          {"type": "SizedBox", "id": "{{widgetId}}-err-gap", "props": {"height": 8}},
                          {"type": "Text", "id": "{{widgetId}}-err-text", "props": {"text": "{{errorMessage}}", "textStyle": "bodySmall", "color": "error"}}
                        ]
                      }]
                    }]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-ready",
                    "props": {"visible": "{{ready}}"},
                    "children": [{
                      "type": "ListView",
                      "id": "{{widgetId}}-scroll",
                      "props": {"padding": "md"},
                      "children": [{
                        "type": "SelectableText",
                        "id": "{{widgetId}}-content",
                        "props": {
                          "text": "{{data.content}}",
                          "textStyle": "bodyMedium",
                          "color": "onSurface"
                        }
                      }]
                    }]
                  }
                ]
              }]
            }
          ]
        }]
      }
    },
    {
      "metadata": {
        "type": "FileNavigator",
        "tier": 2,
        "description": "File browser for a Tercen project. Lists project documents (files, schemas, workflows) with selection support.",
        "props": {
          "projectId": {
            "type": "string",
            "required": false,
            "description": "Project ID to browse. If omitted, prompts user."
          }
        },
        "emittedEvents": ["navigator.focusChanged"],
        "acceptedActions": ["onTap"]
      },
      "template": {
        "type": "PromptRequired",
        "id": "{{widgetId}}-prompt",
        "props": {
          "fields": [
            {"name": "projectId", "label": "Project ID", "default": "2076952ae523bb4d472e283b9e000121"}
          ]
        },
        "children": [{
          "type": "Column",
          "id": "{{widgetId}}-root",
          "props": {"crossAxisAlignment": "stretch"},
          "children": [
            {
              "type": "Container",
              "id": "{{widgetId}}-toolbar",
              "props": {"color": "surfaceContainerHigh", "padding": "sm"},
              "children": [{
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": {"mainAxisAlignment": "spaceBetween"},
                "children": [
                  {"type": "Text", "id": "{{widgetId}}-title", "props": {"text": "Navigator", "textStyle": "labelMedium", "color": "onSurface"}},
                  {"type": "Text", "id": "{{widgetId}}-filter-label", "props": {"text": "All types", "textStyle": "labelSmall", "color": "onSurfaceMuted"}}
                ]
              }]
            },
            {
              "type": "Expanded",
              "id": "{{widgetId}}-body",
              "children": [{
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "projectDocumentService",
                  "method": "findProjectObjectsByLastModifiedDate",
                  "args": [["{{projectId}}", ""], ["{{projectId}}", "\uf000"], 50]
                },
                "children": [
                  {
                    "type": "Conditional", "id": "{{widgetId}}-loading",
                    "props": {"visible": "{{loading}}"},
                    "children": [{"type": "Center", "id": "{{widgetId}}-spinner", "children": [{"type": "LoadingIndicator", "id": "{{widgetId}}-li", "props": {"variant": "skeleton", "text": "Loading…"}}]}]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-error",
                    "props": {"visible": "{{error}}"},
                    "children": [{"type": "Center", "id": "{{widgetId}}-err-center", "children": [{"type": "Text", "id": "{{widgetId}}-err-text", "props": {"text": "Error: {{errorMessage}}", "color": "error"}}]}]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-ready",
                    "props": {"visible": "{{ready}}"},
                    "children": [{
                      "type": "ListView", "id": "{{widgetId}}-lv", "props": {"padding": 4},
                      "children": [{
                        "type": "ForEach", "id": "{{widgetId}}-fe", "props": {"items": "{{data}}"},
                        "children": [{
                          "type": "Action", "id": "tap-{{item.id}}",
                          "props": {"gesture": "onTap", "channel": "navigator.focusChanged", "payload": {"nodeId": "{{item.id}}", "nodeType": "{{item.kind}}", "nodeName": "{{item.name}}"}},
                          "children": [{
                            "type": "ReactTo", "id": "rt-{{item.id}}",
                            "props": {"channel": "navigator.focusChanged", "match": {"nodeId": "{{item.id}}"}, "overrideProps": {"color": "primaryContainer"}},
                            "children": [{
                              "type": "Padding", "id": "pad-{{item.id}}", "props": {"padding": "sm"},
                              "children": [{
                                "type": "Row", "id": "row-{{item.id}}",
                                "children": [
                                  {"type": "Icon", "id": "icon-{{item.id}}", "props": {"icon": "description", "size": 16, "color": "onSurfaceVariant"}},
                                  {"type": "SizedBox", "id": "gap-{{item.id}}", "props": {"width": 8}},
                                  {"type": "Expanded", "id": "exp-{{item.id}}", "children": [{"type": "Text", "id": "name-{{item.id}}", "props": {"text": "{{item.name}}", "textStyle": "bodySmall"}}]},
                                  {"type": "Text", "id": "kind-{{item.id}}", "props": {"text": "{{item.kind}}", "textStyle": "labelSmall", "color": "onSurfaceMuted"}}
                                ]
                              }]
                            }]
                          }]
                        }]
                      }]
                    }]
                  }
                ]
              }]
            }
          ]
        }]
      }
    },
    {
      "metadata": {
        "type": "AuditTrail",
        "tier": 2,
        "description": "Compliance and regulatory log review tool for Tercen. Displays a unified timeline of platform activity events (object creation, modification, deletion, workflow execution) with resizable columns, sortable headers, column-level filters, and date-range filtering. Supports detail panel inspection, multi-select with send-to-Chat for hallucination checking, CSV export, and EventBus-driven scope control.",

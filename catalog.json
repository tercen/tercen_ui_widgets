{
  "widgets": [
    {
      "metadata": {
        "type": "WorkflowViewer",
        "tier": 2,
        "description": "Interactive flowchart viewer for Tercen workflows. Displays steps as a DAG with connectors, supports selection, inline rename, run/stop/reset actions, and step state visualization. Publishes focus events when steps are selected and action events for run/stop/reset. Subscribes to step state changes from the server.",
        "props": {
          "workflowId": {
            "type": "string",
            "required": true,
            "description": "ID of the workflow to display"
          },
          "projectId": {
            "type": "string",
            "required": true,
            "description": "ID of the project containing the workflow"
          }
        },
        "emittedEvents": [
          "workflow.focusChanged",
          "workflow.openStepViewer",
          "workflow.runWorkflow",
          "workflow.stopWorkflow",
          "workflow.resetWorkflow",
          "workflow.runStep",
          "workflow.stopStep",
          "workflow.resetStep",
          "workflow.stepRenamed",
          "workflow.stepMoved"
        ],
        "acceptedActions": ["onTap", "onDoubleTap"]
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "#1E1E1E", "padding": 8 },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "Workflow Viewer", "fontSize": 13, "fontWeight": "bold", "color": "#10B981" }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-id-label",
                    "props": { "text": "{{props.workflowId}}", "fontSize": 11, "color": "grey" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "workflowService",
                  "method": "get",
                  "args": ["{{props.workflowId}}"]
                },
                "children": [
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-loading",
                    "props": { "visible": "{{loading}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-spinner",
                        "children": [
                          {
                            "type": "LoadingIndicator",
                            "id": "{{widgetId}}-li",
                            "props": { "variant": "skeleton", "text": "Loading workflow…" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-error",
                    "props": { "visible": "{{error}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-err-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-err-text",
                            "props": { "text": "Error: {{errorMessage}}", "color": "red" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-ready",
                    "props": { "visible": "{{ready}}" },
                    "children": [
                      {
                        "type": "Column",
                        "id": "{{widgetId}}-wf-col",
                        "props": { "crossAxisAlignment": "center" },
                        "children": [
                          {
                            "type": "Padding",
                            "id": "{{widgetId}}-wf-pad",
                            "props": { "padding": 16 },
                            "children": [
                              {
                                "type": "Text",
                                "id": "{{widgetId}}-wf-name",
                                "props": { "text": "{{data.name}}", "fontSize": 16, "fontWeight": "bold" }
                              }
                            ]
                          },
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-step-count",
                            "props": { "text": "Workflow loaded — use native viewer for full flowchart", "fontSize": 12, "color": "grey" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "DataTableViewer",
        "tier": 2,
        "description": "Tabular data viewer for Tercen tables and computed results. Displays rows and columns with sorting, search, cell annotation editing, and CSV export. Publishes table selection events when a table is loaded and annotation save events when edits are committed.",
        "props": {
          "tableId": {
            "type": "string",
            "required": true,
            "description": "ID of the table to display"
          },
          "tableName": {
            "type": "string",
            "required": false,
            "default": "",
            "description": "Display name for the table"
          },
          "tableKind": {
            "type": "string",
            "required": false,
            "default": "tableSchema",
            "values": ["tableSchema", "computedTable", "joinOperator"],
            "description": "Kind of table schema to fetch"
          }
        },
        "emittedEvents": [
          "system.selection.table",
          "system.data.annotationSaved"
        ],
        "acceptedActions": ["onTap"]
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "#1E1E1E", "padding": 8 },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "{{props.tableName}}", "fontSize": 13, "fontWeight": "bold", "color": "#F59E0B" }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-kind-label",
                    "props": { "text": "{{props.tableKind}}", "fontSize": 11, "color": "grey" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "tableSchemaService",
                  "method": "get",
                  "args": ["{{props.tableId}}"]
                },
                "children": [
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-loading",
                    "props": { "visible": "{{loading}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-spinner",
                        "children": [
                          {
                            "type": "LoadingIndicator",
                            "id": "{{widgetId}}-li",
                            "props": { "variant": "skeleton", "text": "Loading table…" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-error",
                    "props": { "visible": "{{error}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-err-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-err-text",
                            "props": { "text": "Error: {{errorMessage}}", "color": "red" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-ready",
                    "props": { "visible": "{{ready}}" },
                    "children": [
                      {
                        "type": "ListView",
                        "id": "{{widgetId}}-lv",
                        "props": { "padding": 4 },
                        "children": [
                          {
                            "type": "Padding",
                            "id": "{{widgetId}}-header-pad",
                            "props": { "padding": 8 },
                            "children": [
                              {
                                "type": "Text",
                                "id": "{{widgetId}}-header",
                                "props": { "text": "Table loaded — use native viewer for full grid", "fontSize": 12, "color": "grey" }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "ChatBox",
        "tier": 2,
        "description": "LLM chat interface for Tercen. Displays a message thread with markdown-rich responses, syntax-highlighted code blocks, and session management. Sends user messages with focus context to the LLM and emits action intents on the EventBus (create step, open file, navigate workflows). Receives focus context from other widgets to provide situational awareness to the AI.",
        "props": {},
        "emittedEvents": [
          "createStep",
          "openFile",
          "openWorkflow",
          "navigateToStep",
          "navigateTo",
          "refreshTree",
          "workflowUpdated"
        ],
        "acceptedActions": []
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "surfaceContainerHigh", "padding": "sm" },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "IconButton",
                    "id": "{{widgetId}}-new-session",
                    "props": {
                      "icon": "add",
                      "channel": "chat.newSession",
                      "tooltip": "New Session",
                      "size": 18,
                      "color": "primary"
                    }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "Chat", "textStyle": "labelMedium", "color": "onSurface" }
                  },
                  {
                    "type": "IconButton",
                    "id": "{{widgetId}}-history",
                    "props": {
                      "icon": "schedule",
                      "channel": "chat.showHistory",
                      "tooltip": "Chat History",
                      "size": 18,
                      "color": "onSurfaceVariant"
                    }
                  }
                ]
              }
            ]
          },
          {
            "type": "Divider",
            "id": "{{widgetId}}-divider-top",
            "props": { "height": 1, "color": "outlineVariant" }
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "Center",
                "id": "{{widgetId}}-empty",
                "children": [
                  {
                    "type": "Column",
                    "id": "{{widgetId}}-empty-col",
                    "props": { "mainAxisAlignment": "center" },
                    "children": [
                      {
                        "type": "Icon",
                        "id": "{{widgetId}}-empty-icon",
                        "props": { "icon": "chat", "size": 48, "color": "onSurfaceMuted" }
                      },
                      {
                        "type": "SizedBox",
                        "id": "{{widgetId}}-empty-spacer",
                        "props": { "height": 12 }
                      },
                      {
                        "type": "Text",
                        "id": "{{widgetId}}-empty-msg",
                        "props": { "text": "Start a conversation", "textStyle": "titleMedium", "color": "onSurfaceVariant" }
                      },
                      {
                        "type": "SizedBox",
                        "id": "{{widgetId}}-empty-spacer2",
                        "props": { "height": 4 }
                      },
                      {
                        "type": "Text",
                        "id": "{{widgetId}}-empty-detail",
                        "props": { "text": "Ask a question or give an instruction", "textStyle": "bodySmall", "color": "onSurfaceMuted" }
                      }
                    ]
                  }
                ]
              }
            ]
          },
          {
            "type": "Divider",
            "id": "{{widgetId}}-divider-bottom",
            "props": { "height": 1, "color": "outlineVariant" }
          },
          {
            "type": "Container",
            "id": "{{widgetId}}-compose",
            "props": { "color": "surface", "padding": "sm" },
            "children": [
              {
                "type": "Column",
                "id": "{{widgetId}}-compose-col",
                "props": { "crossAxisAlignment": "stretch" },
                "children": [
                  {
                    "type": "TextField",
                    "id": "{{widgetId}}-input",
                    "props": {
                      "hint": "Type a message...",
                      "maxLines": 4,
                      "autofocus": true
                    }
                  },
                  {
                    "type": "SizedBox",
                    "id": "{{widgetId}}-input-spacer",
                    "props": { "height": 4 }
                  },
                  {
                    "type": "Row",
                    "id": "{{widgetId}}-bottom-bar",
                    "props": { "mainAxisAlignment": "end" },
                    "children": [
                      {
                        "type": "Spacer",
                        "id": "{{widgetId}}-bar-spacer",
                        "props": {}
                      },
                      {
                        "type": "IconButton",
                        "id": "{{widgetId}}-send",
                        "props": {
                          "icon": "send",
                          "channel": "chat.send",
                          "tooltip": "Send",
                          "size": 20,
                          "color": "primary"
                        }
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "DocumentEditor",
        "tier": 2,
        "description": "Markdown and plain-text file viewer/editor with dual modes (Source and Rendered). Supports WYSIWYG formatting controls (bold, italic, headings, lists, links, images, code blocks), undo/redo, and save. Publishes content-changed events when the document is saved.",
        "props": {
          "fileId": {
            "type": "string",
            "required": true,
            "description": "Tercen file ID to load and edit"
          },
          "projectId": {
            "type": "string",
            "required": true,
            "description": "Project ID containing the file"
          }
        },
        "emittedEvents": [
          "system.document.dirty"
        ],
        "acceptedActions": []
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "#1E1E1E", "padding": 8 },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "Document Editor", "fontSize": 13, "fontWeight": "bold", "color": "#6366F1" }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-file-label",
                    "props": { "text": "{{props.fileId}}", "fontSize": 11, "color": "grey" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "fileService",
                  "method": "get",
                  "args": ["{{props.fileId}}"]
                },
                "children": [
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-loading",
                    "props": { "visible": "{{loading}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-spinner",
                        "children": [
                          {
                            "type": "LoadingIndicator",
                            "id": "{{widgetId}}-li",
                            "props": { "variant": "skeleton", "text": "Loading document…" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-error",
                    "props": { "visible": "{{error}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-err-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-err-text",
                            "props": { "text": "Error: {{errorMessage}}", "color": "red" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-ready",
                    "props": { "visible": "{{ready}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-ready-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-ready-text",
                            "props": { "text": "Document loaded — use native editor for full editing", "fontSize": 12, "color": "grey" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "FileNavigator",
        "tier": 2,
        "description": "File browser for a Tercen project. Lists project documents (files, schemas, workflows) with selection support.",
        "props": {
          "projectId": {
            "type": "string",
            "required": false,
            "description": "Project ID to browse. If omitted, prompts user."
          }
        },
        "emittedEvents": ["navigator.focusChanged"],
        "acceptedActions": ["onTap"]
      },
      "template": {
        "type": "PromptRequired",
        "id": "{{widgetId}}-prompt",
        "props": {
          "fields": [
            {"name": "projectId", "label": "Project ID", "default": "2076952ae523bb4d472e283b9e000121"}
          ]
        },
        "children": [{
          "type": "Column",
          "id": "{{widgetId}}-root",
          "props": {"crossAxisAlignment": "stretch"},
          "children": [
            {
              "type": "Container",
              "id": "{{widgetId}}-toolbar",
              "props": {"color": "surfaceContainerHigh", "padding": "sm"},
              "children": [{
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": {"mainAxisAlignment": "spaceBetween"},
                "children": [
                  {"type": "Text", "id": "{{widgetId}}-title", "props": {"text": "Navigator", "textStyle": "labelMedium", "color": "onSurface"}},
                  {"type": "Text", "id": "{{widgetId}}-filter-label", "props": {"text": "All types", "textStyle": "labelSmall", "color": "onSurfaceMuted"}}
                ]
              }]
            },
            {
              "type": "Expanded",
              "id": "{{widgetId}}-body",
              "children": [{
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "projectDocumentService",
                  "method": "findProjectObjectsByLastModifiedDate",
                  "args": [["{{projectId}}", ""], ["{{projectId}}", "\uf000"], 50]
                },
                "children": [
                  {
                    "type": "Conditional", "id": "{{widgetId}}-loading",
                    "props": {"visible": "{{loading}}"},
                    "children": [{"type": "Center", "id": "{{widgetId}}-spinner", "children": [{"type": "LoadingIndicator", "id": "{{widgetId}}-li", "props": {"variant": "skeleton", "text": "Loading…"}}]}]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-error",
                    "props": {"visible": "{{error}}"},
                    "children": [{"type": "Center", "id": "{{widgetId}}-err-center", "children": [{"type": "Text", "id": "{{widgetId}}-err-text", "props": {"text": "Error: {{errorMessage}}", "color": "error"}}]}]
                  },
                  {
                    "type": "Conditional", "id": "{{widgetId}}-ready",
                    "props": {"visible": "{{ready}}"},
                    "children": [{
                      "type": "ListView", "id": "{{widgetId}}-lv", "props": {"padding": 4},
                      "children": [{
                        "type": "ForEach", "id": "{{widgetId}}-fe", "props": {"items": "{{data}}"},
                        "children": [{
                          "type": "Action", "id": "tap-{{item.id}}",
                          "props": {"gesture": "onTap", "channel": "navigator.focusChanged", "payload": {"nodeId": "{{item.id}}", "nodeType": "{{item.kind}}", "nodeName": "{{item.name}}"}},
                          "children": [{
                            "type": "ReactTo", "id": "rt-{{item.id}}",
                            "props": {"channel": "navigator.focusChanged", "match": {"nodeId": "{{item.id}}"}, "overrideProps": {"color": "primaryContainer"}},
                            "children": [{
                              "type": "Padding", "id": "pad-{{item.id}}", "props": {"padding": "sm"},
                              "children": [{
                                "type": "Row", "id": "row-{{item.id}}",
                                "children": [
                                  {"type": "Icon", "id": "icon-{{item.id}}", "props": {"icon": "description", "size": 16, "color": "onSurfaceVariant"}},
                                  {"type": "SizedBox", "id": "gap-{{item.id}}", "props": {"width": 8}},
                                  {"type": "Expanded", "id": "exp-{{item.id}}", "children": [{"type": "Text", "id": "name-{{item.id}}", "props": {"text": "{{item.name}}", "textStyle": "bodySmall"}}]},
                                  {"type": "Text", "id": "kind-{{item.id}}", "props": {"text": "{{item.kind}}", "textStyle": "labelSmall", "color": "onSurfaceMuted"}}
                                ]
                              }]
                            }]
                          }]
                        }]
                      }]
                    }]
                  }
                ]
              }]
            }
          ]
        }]
      }
    },
    {
      "metadata": {
        "type": "AuditTrail",
        "tier": 2,
        "description": "Compliance and regulatory log review tool for Tercen. Displays a unified timeline of platform activity events (object creation, modification, deletion, workflow execution) with resizable columns, sortable headers, column-level filters, and date-range filtering. Supports detail panel inspection, multi-select with send-to-Chat for hallucination checking, CSV export, and EventBus-driven scope control.",
        "props": {},
        "emittedEvents": [
          "window.intent"
        ],
        "acceptedActions": ["openAuditTrail"]
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "#1E1E1E", "padding": 8 },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "Audit Trail", "fontSize": 13, "fontWeight": "bold", "color": "#0D9488" }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-scope-label",
                    "props": { "text": "No scope selected", "fontSize": 11, "color": "grey" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "Center",
                "id": "{{widgetId}}-empty",
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-empty-text",
                    "props": { "text": "Select a scope to view audit events", "fontSize": 12, "color": "grey" }
                  }
                ]
              }
            ]
          }
        ]
      }
    },
    {
      "metadata": {
        "type": "PngViewer",
        "tier": 2,
        "description": "Image annotation and visual context tool for Tercen. Displays PNG images from workflow step outputs or project files with pan and zoom navigation. Provides six drawing tools (polygon, rectangle, circle, arrow, freehand, text) for annotating regions of interest. Sends annotated image and structured coordinate data to Chat as LLM context via EventBus.",
        "props": {
          "resourceId": {
            "type": "string",
            "required": true,
            "description": "ID of the PNG image resource in Tercen (step output or project file)"
          },
          "resourceType": {
            "type": "string",
            "required": true,
            "values": ["stepOutput", "projectFile"],
            "description": "Type of image resource — either a workflow step output or a project file"
          }
        },
        "emittedEvents": [
          "window.intent",
          "visualization.annotations.send"
        ],
        "acceptedActions": []
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "type": "Container",
            "id": "{{widgetId}}-toolbar",
            "props": { "color": "#1E1E1E", "padding": 8 },
            "children": [
              {
                "type": "Row",
                "id": "{{widgetId}}-toolbar-row",
                "props": { "mainAxisAlignment": "spaceBetween" },
                "children": [
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-title",
                    "props": { "text": "PNG Viewer", "fontSize": 13, "fontWeight": "bold", "color": "#66FF7F" }
                  },
                  {
                    "type": "Text",
                    "id": "{{widgetId}}-resource-label",
                    "props": { "text": "{{props.resourceType}}", "fontSize": 11, "color": "grey" }
                  }
                ]
              }
            ]
          },
          {
            "type": "Expanded",
            "id": "{{widgetId}}-body",
            "children": [
              {
                "type": "DataSource",
                "id": "{{widgetId}}-ds",
                "props": {
                  "service": "imageDataService",
                  "method": "get",
                  "args": ["{{props.resourceType}}", "{{props.resourceId}}"]
                },
                "children": [
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-loading",
                    "props": { "visible": "{{loading}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-spinner",
                        "children": [
                          {
                            "type": "LoadingIndicator",
                            "id": "{{widgetId}}-li",
                            "props": { "variant": "skeleton", "text": "Loading image…" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-error",
                    "props": { "visible": "{{error}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-err-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-err-text",
                            "props": { "text": "Error: {{errorMessage}}", "color": "red" }
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "type": "Conditional",
                    "id": "{{widgetId}}-ready",
                    "props": { "visible": "{{ready}}" },
                    "children": [
                      {
                        "type": "Center",
                        "id": "{{widgetId}}-ready-center",
                        "children": [
                          {
                            "type": "Text",
                            "id": "{{widgetId}}-ready-text",
                            "props": { "text": "Image loaded — use native viewer for annotations and pan/zoom", "fontSize": 12, "color": "grey" }
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}


{
  "widgets": [
    {
      "metadata": {
        "type": "PngViewer",
        "kind": "window",
        "tier": 2,
        "typeColor": "#66FF7F",
        "tabLabel": "PNG Viewer",
        "description": "Image viewer and annotation tool for workflow step output plots. Displays PNG images with zoom/pan, provides 6 drawing tools (polygon, rectangle, circle, arrow, freehand, text), and supports sending annotated images to Chat or saving as PNG download. Use when the user wants to view, annotate, or share charts and images generated by a workflow step.",
        "emittedEvents": [
          "window.intent",
          "visualization.annotations.send"
        ],
        "inboundEvents": [
          "window.{{widgetId}}.command"
        ],
        "handlesIntent": {
          "intent": "openStepImages",
          "propsMap": {
            "workflowId": "workflowId",
            "stepId": "stepId"
          },
          "windowTitle": "Images: {{stepName}}",
          "windowSize": "large"
        },
        "props": {
          "workflowId": { "type": "string", "required": true },
          "stepId": { "type": "string", "required": true }
        },
        "domain": "image",
        "capabilities": ["browse", "annotate", "export"],
        "selectionMode": "none",
        "dataSource": "tableSchemaService.getStepImages"
      },
      "template": {
        "type": "Column",
        "id": "{{widgetId}}-root",
        "props": { "crossAxisAlignment": "stretch" },
        "children": [
          {
            "_comment": "PromptRequired gate — requires workflowId + stepId from intent",
            "type": "PromptRequired",
            "id": "{{widgetId}}-prompt",
            "props": {
              "fields": [
                { "name": "workflowId", "label": "Workflow ID" },
                { "name": "stepId", "label": "Step ID" }
              ]
            },
            "children": [
              {
                "_comment": "Body — DataSource fetches step images",
                "type": "Expanded",
                "id": "{{widgetId}}-body",
                "children": [
                  {
                    "type": "DataSource",
                    "id": "{{widgetId}}-ds",
                    "props": {
                      "service": "tableSchemaService",
                      "method": "getStepImages",
                      "args": ["{{props.workflowId}}", "{{props.stepId}}"]
                    },
                    "children": [
                      {
                        "_comment": "Loading state",
                        "type": "Conditional",
                        "id": "{{widgetId}}-loading",
                        "props": { "visible": "{{loading}}" },
                        "children": [
                          {
                            "type": "Center",
                            "id": "{{widgetId}}-loading-center",
                            "children": [
                              {
                                "type": "Column",
                                "id": "{{widgetId}}-loading-col",
                                "props": { "mainAxisAlignment": "center", "mainAxisSize": "min" },
                                "children": [
                                  {
                                    "type": "LoadingIndicator",
                                    "id": "{{widgetId}}-spinner",
                                    "props": { "variant": "spinner" }
                                  },
                                  { "type": "SizedBox", "id": "{{widgetId}}-loading-gap", "props": { "height": 12 } },
                                  {
                                    "type": "Text",
                                    "id": "{{widgetId}}-loading-text",
                                    "props": {
                                      "text": "Loading images\u2026",
                                      "textStyle": "bodyMedium",
                                      "color": "onSurfaceMuted"
                                    }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "_comment": "Error state",
                        "type": "Conditional",
                        "id": "{{widgetId}}-error",
                        "props": { "visible": "{{error}}" },
                        "children": [
                          {
                            "type": "Center",
                            "id": "{{widgetId}}-err-center",
                            "children": [
                              {
                                "type": "Column",
                                "id": "{{widgetId}}-err-col",
                                "props": { "mainAxisAlignment": "center", "crossAxisAlignment": "center" },
                                "children": [
                                  {
                                    "type": "Icon",
                                    "id": "{{widgetId}}-err-icon",
                                    "props": { "icon": "triangle-exclamation", "size": 32, "color": "error" }
                                  },
                                  { "type": "SizedBox", "id": "{{widgetId}}-err-g1", "props": { "height": 12 } },
                                  {
                                    "type": "Text",
                                    "id": "{{widgetId}}-err-title",
                                    "props": { "text": "Something went wrong", "textStyle": "bodyMedium", "color": "error" }
                                  },
                                  { "type": "SizedBox", "id": "{{widgetId}}-err-g2", "props": { "height": 4 } },
                                  {
                                    "type": "Text",
                                    "id": "{{widgetId}}-err-msg",
                                    "props": { "text": "{{errorMessage}}", "textStyle": "bodySmall", "color": "onSurfaceMuted" }
                                  },
                                  { "type": "SizedBox", "id": "{{widgetId}}-err-g3", "props": { "height": 16 } },
                                  {
                                    "type": "SecondaryButton",
                                    "id": "{{widgetId}}-retry-btn",
                                    "props": {
                                      "text": "Retry",
                                      "channel": "ds.{{widgetId}}-ds.refresh"
                                    }
                                  }
                                ]
                              }
                            ]
                          }
                        ]
                      },
                      {
                        "_comment": "Ready state — AnnotatedImageViewer handles toolbar, tabs, canvas, annotations",
                        "type": "Conditional",
                        "id": "{{widgetId}}-ready",
                        "props": { "visible": "{{ready}}" },
                        "children": [
                          {
                            "type": "Expanded",
                            "id": "{{widgetId}}-viewer-exp",
                            "children": [
                              {
                                "type": "AnnotatedImageViewer",
                                "id": "{{widgetId}}-viewer",
                                "props": {
                                  "images": "{{data.images}}",
                                  "sendChannel": "visualization.annotations.send"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    }
  ]
}
